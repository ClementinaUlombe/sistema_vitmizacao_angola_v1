model Report {
  id                    Int      @id @default(autoincrement())
  userId                Int?     // Adicionado: ID do utilizador que enviou (se logado)
  name                  String?
  email                 String?
  subject               String
  message               String
  status                String   @default("Pendente") // Adicionado: Pendente, Em AnûÀlise, Encaminhado, Resolvido
  age                   String?
  gender                String?
  occupation            String?
  educationLevel        String?
  residenceTime         String?
  neighborhood          String?
  wasVictim             Boolean?
  crimeTypes            String?  // JSON array of selected crimes
  theft                 Boolean? @default(false)
  robbery               Boolean? @default(false)
  aggression            Boolean? @default(false)
  domesticViolence      Boolean? @default(false)
  rape                  Boolean? @default(false)
  fraud                 Boolean? @default(false)
  cybercrime            Boolean? @default(false)
