  neighborCooperation            String? // Novo: Coluna '@36.ComodescrevearelaûÏûÈoentrevizinhosemtermosdecooperaûÏûÈopar'
  communityInitiativeParticipation String? // Novo: Coluna '@37.VocûˆparticipadealgumainiciativacomunitûÀriavoltadaparaaseguSesimqual'
  securityImprovementSuggestions String? // Novo: Coluna '@38.QuaismedidasvocûˆsugeririaparamelhoraraseguranûÏanobairro'
