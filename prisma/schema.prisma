  residentNumber                 String   @unique // Novo: Coluna 'NĂşmero' do Excel
  surveyDate                     DateTime? // Novo: Coluna 'Data' do Excel
  ageGroup                       String // Mapeia para 'Idade'
  gender                         String // Mapeia para 'GĂ©nero'
  occupation                     String // Mapeia para 'OcupaĂ§ĂŁo'
  residenceTime                  String // Mapeia para 'Tempo_de_residĂŞncia_no_bairro'
  neighborhood                   String // Mapeia para 'Bairro'
  educationLevel                 String // Mapeia para 'Escolaridade'
  school                         String? // Novo: Coluna 'ESCOLA'
  emailContact                   String? // Novo: Coluna 'DirecciĂłndecorreoelectrĂłnicofilter_$' (renomeado para clareza)
  // protectionMeasures String[] // Alterado para campos Boolean? individuais
  protectionMeasureP1            Boolean? // Novo: Coluna 'p1'
