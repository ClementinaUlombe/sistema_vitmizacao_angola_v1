  protectionMeasureP3            Boolean? // Novo: Coluna 'p3'
  protectionMeasureP4            Boolean? // Novo: Coluna 'p4'
  protectionMeasureP5            Boolean? // Novo: Coluna 'p5'
  protectionMeasureP6            Boolean? // Novo: Coluna 'p6'
  protectionMeasureP7            Boolean? // Novo: Coluna 'p7'
  protectionMeasureP8            Boolean? // Novo: Coluna 'p8'
  protectionMeasureP9            Boolean? // Novo: Coluna 'p9'
  protectionMeasureP10           Boolean? // Novo: Coluna 'p10'
  crimeImpactOnDailyLife         String? // Novo: Coluna '@35.AcriminalidadeafetousuarotinadiĂˇriaoudesuafamĂ­liaDequemaneira'
  neighborCooperation            String? // Novo: Coluna '@36.ComodescrevearelaĂ§ĂŁoentrevizinhosemtermosdecooperaĂ§ĂŁopar'
  communityInitiativeParticipation String? // Novo: Coluna '@37.VocĂŞparticipadealgumainiciativacomunitĂˇriavoltadaparaaseguSesimqual'
  securityImprovementSuggestions String? // Novo: Coluna '@38.QuaismedidasvocĂŞsugeririaparamelhoraraseguranĂ§anobairro'
  victimSupportServicesKnowledge Boolean? // Novo: Coluna '@39.VocĂŞconheceserviĂ§osdeapoioĂ svĂ­timasdecrimenobairro'
