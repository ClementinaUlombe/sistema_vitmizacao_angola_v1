// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String?
  email     String   @unique
  password  String
  role      String   @default("RESEARCHER")
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  residents Resident[]
}

model Resident {
  id                             Int      @id @default(autoincrement())
  residentNumber                 String   @unique
  surveyDate                     DateTime? @default(now())
  status                         String   @default("PENDENTE") // PENDENTE, VALIDADO, REJEITADO
  researcherId                   Int?
  researcher                     User?    @relation(fields: [researcherId], references: [id])
  ageGroup                       String
  gender                         String
  occupation                     String?
  residenceTime                  String?
  neighborhood                   String
  educationLevel                 String?
  school                         String? 
  emailContact                   String? 
  protectionMeasureP1            Boolean? 
  protectionMeasureP2            Boolean? 
  protectionMeasureP3            Boolean? 
  protectionMeasureP4            Boolean? 
  protectionMeasureP5            Boolean? 
  protectionMeasureP6            Boolean? 
  protectionMeasureP7            Boolean? 
  protectionMeasureP8            Boolean? 
  protectionMeasureP9            Boolean? 
  protectionMeasureP10           Boolean? 
  crimeImpactOnDailyLife         String? 
  neighborCooperation            String? 
  communityInitiativeParticipation String? 
  securityImprovementSuggestions String? 
  victimSupportServicesKnowledge Boolean? 
  crimeImpactDetails             String? 
  improvementSuggestionsDetails  String? 
  communityInitiativeDetails     String? 
  filterColumn                   String? 

  victimizations                 Victimization[]
  securityPerceptions            SecurityPerception[]
}

model Victimization {
  id                             Int      @id @default(autoincrement())
  residentId                     Int
  resident                       Resident @relation(fields: [residentId], references: [id])
  wasVictim                      Boolean // Vitima
  crimeGeneral                   String? // Crime
  theft                          Boolean? // Furto
  robbery                        Boolean? // Roubo
  aggression                     Boolean? // Agressão
  burglary                       Boolean? // Arrombamento
  domesticViolence               Boolean? // VioDom
  homicide                       Boolean? // Homicidio
  rape                           Boolean? // Estupro
  drugTrafficking                Boolean? // TraDroga
  vandalism                      Boolean? // Vandalismo
  extortion                      Boolean? // Extorsão
  kidnapping                     Boolean? // Sequestro
  fraud                          Boolean? // Fraude
  cybercrime                     Boolean? // CrimeCibernetico
  otherCrime                     String? // Outro
  crimeFrequency                 String? // Quantasvezes
  reportedCrimeQuestion          String? // VAR00056 
  reportedCrime                  Boolean? // Denunciou
  notReportingReasonA1           Boolean? 
  notReportingReasonA2           Boolean? 
  notReportingReasonA3           Boolean? 
  notReportingReasonA4           Boolean? 
  notReportingReasonA5           Boolean? 
  notReportingReasonA6           Boolean? 
  notReportingReasonA7           Boolean? 
  notReportingReasonA8           Boolean? 
  notReportingReasonA9           Boolean? 
  notReportingReasonA10          Boolean? 
  crimeYear                      Int? 
  crimeMonth                     String? 
  crimeHour                      String? 
  crimeLocation                  String? 
  perpetratorCount               String?
  damages                        String? 
  minorsInvolved                 Boolean? 
  crimesByWomen                  Boolean? 
  crimesAgainstWomen             Boolean? 
  gangPresence                   Boolean? 
}

model SecurityPerception {
  id                             Int      @id @default(autoincrement())
  residentId                     Int
  resident                       Resident @relation(fields: [residentId], references: [id])
  daySecurity                    String 
  nightSecurity                  String 
  securityComparison             String? 
  mostDangerousAreas             String? 
  mostInsecureHours              String? 
  insecurityFactors              String? 
  insecurityFactorF1             Boolean? 
  insecurityFactorF2             Boolean? 
  insecurityFactorF3             Boolean? 
  insecurityFactorF4             Boolean? 
  insecurityFactorF5             Boolean? 
  insecurityFactorF6             Boolean? 
  insecurityFactorF7             Boolean? 
  insecurityFactorF8             Boolean? 
  insecurityFactorF9             Boolean? 
  insecurityFactorF10            Boolean? 
  insecurityFactorF11            Boolean? 
  insecurityFactorF12            Boolean? 
  insecurityFactorF13            Boolean? 
  crimeFrequencyPerceptionGeneral String? 
  crimeFrequencyPerceptionA      String? 
  crimeFrequencyPerceptionB      String? 
  crimeFrequencyPerceptionC      String? 
  crimeGravityPerception         String? 
  policePresenceEvaluation       String? 
  policeResponseSpeedEvaluation  String? 
  policeEffectivenessEvaluation  String? 
  localPoliceTrustLevel          String? 
  personalPoliceInteraction      String? 
  personalPoliceInteractionDetails String? 
  trustInPoliceAndJusticeSystem  Boolean? 
  victimSupportBelief            Boolean? 
}

model Report {
  id                    Int      @id @default(autoincrement())
  userId                Int?     
  name                  String?
  email                 String?
  subject               String
  message               String
  status                String   @default("Pendente") 
  age                   String?
  gender                String?
  occupation            String?
  educationLevel        String?
  residenceTime         String?
  neighborhood          String?
  wasVictim             Boolean?
  crimeTypes            String?  
  theft                 Boolean? @default(false)
  robbery               Boolean? @default(false)
  aggression            Boolean? @default(false)
  domesticViolence      Boolean? @default(false)
  rape                  Boolean? @default(false)
  fraud                 Boolean? @default(false)
  cybercrime            Boolean? @default(false)
  otherCrime            String?
  createdAt             DateTime @default(now())
  read                  Boolean  @default(false)
}
